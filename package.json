{
  "name": "ai-assisted-potential-customer-identification-and-promotion",
  "version": "1.0.0",
  "description": "AI 輔助潛在客戶探勘與推廣系統（學習歷程原型）",
  "main": "main.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "demo": "node backend-server.js",
    "backend": "node backend-server.js",
    "test:unit": "node --test test/unit/api-validate.test.cjs test/unit/static-path.test.cjs test/unit/dedup.test.cjs",
    "test:integration": "node scripts/run-integration-tests.js",
    "test": "npm run test:unit && npm run test:integration",
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never",
    "pack": "electron-builder --dir",
    "dev": "electron . --dev"
  },
  "keywords": [
    "AI",
    "marketing",
    "automation",
    "desktop",
    "app"
  ],
  "author": "AI Marketing Assistant",
  "license": "MIT",
  "dependencies": {
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.aimarketing.assistant",
    "productName": "AI 推銷助手",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*.js",
      "renderer/**/*",
      "assets/**/*",
      "*.html",
      "pages/**/*.html",
      "debug/**/*.html",
      "archive/**/*.html",
      "archive/**/*.css",
      "data/**/*",
      "scripts/**/*",
      "*.css",
      "*.js",
      "pages/**/*.css",
      "*.md",
      "pages/**/*.md",
      "debug/**/*.md",
      "archive/**/*.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI 推銷助手"
    }
  }
} 